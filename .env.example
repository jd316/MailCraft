# ---- Application ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins (use * only for local dev)
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ---- Model provider ----
# "bedrock"   — AWS Bedrock (uses AWS credentials from env/profile; default)
# "gemini"    — Google Gemini API (requires GOOGLE_API_KEY)
# "mock"      — deterministic adapter for automated tests only (APP_ENV=test)
LLM_PROVIDER=bedrock

# Required only for LLM_PROVIDER=gemini or JUDGE_PROVIDER=gemini
GOOGLE_API_KEY=

# Required only for LLM_PROVIDER=bedrock
AWS_REGION=us-east-1

# Model identifiers — Bedrock model IDs or Anthropic model names
MODEL_PRIMARY=mistral.mistral-large-3-675b-instruct
MODEL_SECONDARY=mistral.mistral-small-2402-v1:0
MODEL_JUDGE=mistral.mistral-large-3-675b-instruct
# Optional: route judge calls through a different provider (e.g. "gemini")
# for cross-model evaluation. Leave empty to use LLM_PROVIDER for judging too.
JUDGE_PROVIDER=
# Optional backup model — used once on upstream error before failing.
MODEL_FALLBACK=

# Generation config
GEN_TEMPERATURE=0.3
GEN_MAX_TOKENS=4096
GEN_TIMEOUT_SECONDS=60

# Max bytes accepted per POST body (protects against abuse before parsing).
MAX_BODY_BYTES=32768

# Baseline security headers (set to false to rely on an external gateway).
ENABLE_SECURITY_HEADERS=true

# Retention: delete drafts older than N days via `make clean-drafts`.
# 0 disables cleanup (the default).
DRAFT_RETENTION_DAYS=0

# ---- Persistence ----
# SQLite for assignment mode; switch to postgres URL for production
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ---- Rate limiting ----
RATE_LIMIT_GENERATE=30/minute
RATE_LIMIT_EVAL=3/minute

# ---- Evaluation ----
EVAL_REPORTS_DIR=./eval/reports
EVAL_SCENARIOS_DIR=./eval/scenarios
EVAL_REFERENCES_DIR=./eval/references
# Parallel scenario×config scoring — raise cautiously if provider rate allows.
EVAL_CONCURRENCY=4
